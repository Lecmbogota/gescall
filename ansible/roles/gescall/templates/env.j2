# GesCall Backend .env — {{ subdomain }}
# Generated by Ansible — do not edit manually

# PostgreSQL
PG_USER={{ pg_user }}
PG_PASSWORD={{ pg_password }}
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE={{ pg_database }}

# Redis
REDIS_HOST=localhost
REDIS_PORT={{ redis_port }}

# Asterisk ARI
ARI_URL={{ ari_url }}
ARI_USER={{ ari_user }}
ARI_PASS={{ ari_pass }}

# SIP Trunk (per-client)
SBC_ENDPOINT={{ sip_trunk_endpoint }}
SBC_HOST={{ sip_trunk_host }}
SBC_PORT={{ sip_trunk_port | default(5060) }}
SBC_PREFIX={{ sip_trunk_prefix | default('') }}

# Dialer settings
DIALER_INTERVAL_MS=1000
DIALER_MAX_CONCURRENT=100
DIALER_MAX_CPS=15

# JWT Auth
JWT_SECRET={{ lookup('password', '/dev/null chars=ascii_letters,digits length=64') }}
JWT_EXPIRY=24h

# Piper TTS
PIPER_TTS_URL=http://127.0.0.1:5000

# ClickHouse
CLICKHOUSE_URL=http://127.0.0.1:8123

# Node backend
PORT={{ backend_port }}
NODE_ENV=production

# Subdomain
GESCALL_DOMAIN={{ subdomain }}
CORS_ORIGIN=https://{{ subdomain }},http://{{ subdomain }},http://localhost:5173

# Public API keys (comma-separated, optional)
PUBLIC_API_KEYS=

# Log retention for ClickHouse archiving (days)
LOG_RETENTION_DAYS=30
